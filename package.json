{
  "name": "@khanglvm/llm-router",
  "version": "2.2.1",
  "description": "LLM Router: single gateway endpoint for multi-provider LLMs with unified OpenAI+Anthropic format and seamless fallback",
  "keywords": [
    "llm-router",
    "llm-gateway",
    "ai-proxy",
    "openai-compatible",
    "anthropic-compatible",
    "model-routing",
    "fallback",
    "load-balancing",
    "cloudflare-workers",
    "agent-infra"
  ],
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "llr": "./src/cli-entry.js",
    "llm-router-route": "./src/cli-entry.js"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "build:web-console": "node ./scripts/build-web-console.mjs",
    "start": "node ./src/cli-entry.js start",
    "config": "node ./src/cli-entry.js config",
    "deploy:worker": "node ./src/cli-entry.js deploy",
    "test:provider-live": "node --test --test-concurrency=1 ./test/live-provider-suite.test.js",
    "test:provider-smoke": "npm run test:provider-live",
    "test:amp-smoke": "node ./scripts/amp-smoke-suite.mjs",
    "prepublishOnly": "npm run test:provider-live"
  },
  "dependencies": {
    "@levu/snap": "^0.3.13"
  },
  "devDependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/cli": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.27.3",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "wrangler": "^4.68.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "!src/**/*.spec.js",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "wrangler.toml"
  ]
}
