LLM_ROUTER_TEST_HOST=127.0.0.1
LLM_ROUTER_TEST_PORT=8787
LLM_ROUTER_TEST_TIMEOUT_MS=90000
LLM_ROUTER_TEST_MAX_TOKENS=48
LLM_ROUTER_TEST_REQUEST_TEXT="Reply with exactly: OK"

# Test hostname/zone for routing tests (use local example for CI/public)
LLM_ROUTER_TEST_HOSTNAME=router.example.com
LLM_ROUTER_TEST_ZONE_NAME=example.com

#
# Copy this file to .env.test-suite for local-only real-provider runs.
# .env.test-suite is gitignored on purpose.
#
# The live provider suite covers:
# - CLI config + start + routed API calls
# - TUI model-edit flow with live provider probe
# - Web console discovery/test endpoints plus browser bundle render
#
# Use one or more provider keys below.
#
LLM_ROUTER_TEST_PROVIDER_KEYS=RAMCLOUD,ZAI

LLM_ROUTER_TEST_RAMCLOUD_PROVIDER_ID=ramcloud
LLM_ROUTER_TEST_RAMCLOUD_NAME="RamCloud"
LLM_ROUTER_TEST_RAMCLOUD_API_KEY=sk-...
LLM_ROUTER_TEST_RAMCLOUD_OPENAI_BASE_URL=https://ramclouds.me/v1
LLM_ROUTER_TEST_RAMCLOUD_CLAUDE_BASE_URL=https://ramclouds.me
LLM_ROUTER_TEST_RAMCLOUD_MODELS=minimax-m2.7

LLM_ROUTER_TEST_ZAI_PROVIDER_ID=zai
LLM_ROUTER_TEST_ZAI_NAME="Z.ai"
LLM_ROUTER_TEST_ZAI_API_KEY=sk-...
LLM_ROUTER_TEST_ZAI_OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_ROUTER_TEST_ZAI_CLAUDE_BASE_URL=https://api.z.ai/api/anthropic
LLM_ROUTER_TEST_ZAI_MODELS=glm-4.7-flash

# Generic provider template for other local runs:
# LLM_ROUTER_TEST_PROVIDER_KEYS=EXAMPLE
# LLM_ROUTER_TEST_EXAMPLE_PROVIDER_ID=example
# LLM_ROUTER_TEST_EXAMPLE_NAME="Example Provider"
# LLM_ROUTER_TEST_EXAMPLE_API_KEY=sk-...
# LLM_ROUTER_TEST_EXAMPLE_OPENAI_BASE_URL=https://api.example.com/v1
# LLM_ROUTER_TEST_EXAMPLE_CLAUDE_BASE_URL=https://api.example.com
# LLM_ROUTER_TEST_EXAMPLE_MODELS=model-a,model-b
# LLM_ROUTER_TEST_EXAMPLE_HEADERS_JSON={"X-Env":"local"}
# LLM_ROUTER_TEST_EXAMPLE_OPENAI_HEADERS_JSON={"User-Agent":"Mozilla/5.0"}
# LLM_ROUTER_TEST_EXAMPLE_CLAUDE_HEADERS_JSON={"x-foo":"bar"}
